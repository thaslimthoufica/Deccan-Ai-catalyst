{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: FastAPI (backend)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "jinja": true,
      "envFile": "${workspaceFolder}/backend/.env"
    }
  ]
}
